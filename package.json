{
  "name": "echosdk-monorepo",
  "private": true,
  "description": "EchoSDK monorepo — headless support chat SDK",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "prettier": "^3.1.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "keywords": [
    "react",
    "support",
    "chat",
    "helpdesk",
    "ai",
    "sdk",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/echosdk-react.git"
  },
  "license": "MIT",
  "author": "EchoSDK Team"
}
