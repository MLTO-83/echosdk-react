{
  "name": "@echosdk/shopify-hydrogen",
  "version": "0.1.0",
  "description": "Shopify Hydrogen + Next.js Commerce adapter for @echosdk/react",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nextjs": {
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs",
      "types": "./dist/nextjs.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "peerDependencies": {
    "@echosdk/react": "^1.0.0",
    "@shopify/hydrogen": ">=2024.0.0",
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "@shopify/hydrogen": {
      "optional": true
    }
  },
  "devDependencies": {
    "@echosdk/react": "workspace:*",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "echosdk",
    "shopify",
    "hydrogen",
    "nextjs",
    "react",
    "chat",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/echosdk-react.git"
  },
  "license": "MIT",
  "author": "EchoSDK Team"
}
